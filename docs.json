{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "DocInject",
  "description": "DocInject helps teams create, manage, and deploy SOPs, playbooks, and guides into the tools and workflows they already use.",
  "colors": {
    "primary": "#ea580c",
    "light": "#FAFAFA",
    "dark": "#3F3F46"
  },
  "favicon": {
    "light": "/images/favicon.ico",
    "dark": "/images/favicon.ico"
  },
    "fonts": {
    "family": "Inter",
    "weight": 600
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "section"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Home",
          "icon": "house",
          "href": "/"
        }
      ]
    },
    "directory": "card",
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "expanded": true,
            "pages": [
              "introduction",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Creating Documents",
            "icon": "file-text",
            "expanded": true,
            "pages": [
              "documents/overview",
              "documents/ai-generation",
              "documents/editor",
              "documents/publish-archive"
            ]
          },
          {
            "group": "Sharing & Exporting",
            "icon": "share-2",
            "expanded": true,
            "pages": [
              "sharing/embed",
              "sharing/export",
              "sharing/share-links"
            ]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "expanded": true,
            "pages": [
              "integrations/webhooks",
              "integrations/api-keys",
              "integrations/mcp",
              "integrations/automation-assistant",
              "integrations/inbox"
            ]
          },
          {
            "group": "Team & Settings",
            "icon": "users",
            "expanded": true,
            "pages": [
              "team/members",
              "team/roles",
              "team/billing"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "icon": "book-open",
            "expanded": true,
            "pages": [
              "api/authentication",
              "api/errors"
            ]
          },
          {
            "group": "Documents",
            "icon": "file",
            "expanded": true,
            "pages": [
              "api/documents/list"
            ]
          },
          {
            "group": "Webhooks",
            "icon": "webhook",
            "expanded": true,
            "pages": [
              "api/webhooks/overview",
              "api/webhooks/events"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/docinject_logo_light.png",
    "dark": "/images/docinject_logo_dark.png",
    "href": "https://docinject.com"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Sign Up",
      "href": "https://docinject.com/signup"
    }
  },
  "footer": {
    "socials": {}
  },
  "seo": {
    "indexing": "navigable"
  },
  "interaction": {
    "drilldown": true
  },
  "appearance": {
    "default": "light"
  },
  "background": {
    "color": {
      "dark": "#27272A"
    }
  }
}
