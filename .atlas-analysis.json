  "keyFeatures": [
    "AI-powered document generation from notes, audio, video, and file uploads",
    "Structured editor with sections, steps, and sub-steps",
    "Document versioning and revision history",
    "Embeddable share links for external access without login",
    "Word (.docx) export with custom templates",
    "Webhook events for automation platform integrations (Zapier, Make, n8n, etc.)",
    "REST API with API key authentication",
    "Automation Assistant for generating platform-specific automation recipes",
    "Team management with admin and member roles",
    "Subscription-based plans with per-seat billing"
  ],
